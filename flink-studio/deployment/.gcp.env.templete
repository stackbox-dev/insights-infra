# GCP Configuration Template for Flink Deployment
# Copy this file to .<environment-name>.env (e.g., .sbx-uat.env, .sbx-stag.env)
# and fill in your actual values
# NEVER commit actual .env files with real credentials to git - they're in .gitignore

GCP_PROJECT=sbx-stag

PROJECT_ENVIRONMENT=sbx-uat
FLINK_GCS_SERVICE_ACCOUNT=flink-gcs

# Kubernetes Service Account
K8S_NAMESPACE=flink-studio
K8S_SERVICE_ACCOUNT=flink

